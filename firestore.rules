rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if the request is authenticated with Firebase Auth
    function isAuthenticated() {
      return request.auth != null;
    }

    // Retrieve the user document data from Firestore
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Verify if the authenticated user has an active account in Firestore
    function isActiveUser() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             getUserData().status == 'active';
    }

    // Verify if the authenticated user is an active admin
    function isAdmin() {
      return isActiveUser() && getUserData().role == 'admin';
    }

    match /users/{userId} {
      // Allow user profile read if the user is authenticated and either:
      // 1. Reading their own profile
      // 2. Is an active admin reading any profile
      allow read: if isAuthenticated() && (
        request.auth.uid == userId || 
        isAdmin()
      );
      
      // Allow user profile creation if the user is authenticated and either:
      // 1. Creating their own profile (e.g., initial setup or registration)
      // 2. Is an active admin creating a profile
      allow create: if isAuthenticated() && (
        request.auth.uid == userId || 
        isAdmin()
      );
      
      // Allow user profile update if the user is authenticated and either:
      // 1. Is an active admin updating a profile
      // 2. Is updating their own profile and is active, but is NOT changing their role or status
      allow update: if isAuthenticated() && (
        isAdmin() || (
          request.auth.uid == userId && 
          isActiveUser() && 
          request.resource.data.role == resource.data.role && 
          request.resource.data.status == resource.data.status
        )
      );
      
      // Only active admins can delete user profiles
      allow delete: if isAdmin();
    }

    match /sites/{siteId} {
      // Allow read access to construction sites only for active users (admins or engineers)
      allow read: if isActiveUser();
      
      // Allow write/modify access to construction sites only for active admins
      allow write: if isAdmin();
    }

    match /dailyUpdates/{updateId} {
      // Allow active users (admins or engineers) to read and write daily updates
      allow read, write: if isActiveUser();
    }
    
  }
}
