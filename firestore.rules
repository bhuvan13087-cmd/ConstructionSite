rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if the request is authenticated with Firebase Auth
    function isAuthenticated() {
      return request.auth != null;
    }

    // Retrieve the user document data from Firestore
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Helper functions for new collections
    function isSuperAdmin() {
      return isAuthenticated() && exists(/databases/$(database)/documents/superAdmins/$(request.auth.uid));
    }
    
    function isAdminUser() {
      return isAuthenticated() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isSiteEngineer() {
      return isAuthenticated() && exists(/databases/$(database)/documents/siteEngineers/$(request.auth.uid));
    }

    function getSuperAdminData() {
      return get(/databases/$(database)/documents/superAdmins/$(request.auth.uid)).data;
    }

    function getAdminData() {
      return get(/databases/$(database)/documents/admins/$(request.auth.uid)).data;
    }

    function getSiteEngineerData() {
      return get(/databases/$(database)/documents/siteEngineers/$(request.auth.uid)).data;
    }

    function isActiveSuperAdmin() {
      return isSuperAdmin() && getSuperAdminData().status == 'active';
    }

    function isActiveAdmin() {
      return isAdminUser() && getAdminData().status == 'active';
    }

    function isActiveSiteEngineer() {
      return isSiteEngineer() && getSiteEngineerData().status == 'active';
    }

    // Verify if the authenticated user has an active account in Firestore
    function isActiveUser() {
      return isAuthenticated() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().status == 'active') ||
        isActiveSuperAdmin() || 
        isActiveAdmin() || 
        isActiveSiteEngineer()
      );
    }

    // Verify if the authenticated user is an active admin (includes super admins)
    function isAdmin() {
      return isAuthenticated() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().status == 'active' && (getUserData().role == 'admin' || getUserData().role == 'super_admin' || getUserData().role == 'superadmin')) ||
        isActiveSuperAdmin() || 
        isActiveAdmin()
      );
    }

    match /users/{userId} {
      // Allow user profile read if the user is authenticated and either:
      // 1. Reading their own profile
      // 2. Is an active admin reading any profile
      // 3. Reading the global document categories document
      allow read: if isAuthenticated() && (
        request.auth.uid == userId || 
        isAdmin() ||
        userId == '__document_categories__'
      );
      
      // Allow user profile creation if the user is authenticated and either:
      // 1. Creating their own profile (e.g., initial setup or registration)
      // 2. Is an active admin creating a profile
      allow create: if isAuthenticated() && (
        request.auth.uid == userId || 
        isAdmin()
      );
      
      // Allow user profile update if the user is authenticated and either:
      // 1. Is an active admin updating a profile
      // 2. Is updating their own profile and is active, but is NOT changing their role or status
      allow update: if isAuthenticated() && (
        isAdmin() || (
          request.auth.uid == userId && 
          isActiveUser() && 
          request.resource.data.role == resource.data.role && 
          request.resource.data.status == resource.data.status
        )
      );
      
      // Only active admins can delete user profiles
      allow delete: if isAdmin();
    }

    match /superAdmins/{userId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == userId || 
        isAdmin()
      );
      allow create: if isAuthenticated() && (
        request.auth.uid == userId || 
        isAdmin()
      );
      allow update: if isAuthenticated() && (
        isAdmin() || (
          request.auth.uid == userId && 
          isActiveUser() && 
          request.resource.data.role == resource.data.role && 
          request.resource.data.status == resource.data.status
        )
      );
      allow delete: if isAdmin();
    }

    match /admins/{userId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == userId || 
        isAdmin()
      );
      allow create: if isAuthenticated() && (
        request.auth.uid == userId || 
        isAdmin()
      );
      allow update: if isAuthenticated() && (
        isAdmin() || (
          request.auth.uid == userId && 
          isActiveUser() && 
          request.resource.data.role == resource.data.role && 
          request.resource.data.status == resource.data.status
        )
      );
      allow delete: if isAdmin();
    }

    match /siteEngineers/{userId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == userId || 
        isAdmin()
      );
      allow create: if isAuthenticated() && (
        request.auth.uid == userId || 
        isAdmin()
      );
      allow update: if isAuthenticated() && (
        isAdmin() || (
          request.auth.uid == userId && 
          isActiveUser() && 
          request.resource.data.status == resource.data.status
        )
      );
      allow delete: if isAdmin();
    }

    match /sites/{siteId} {
      // Allow read access to construction sites only for active users (admins or engineers)
      allow read: if isActiveUser();
      
      // Allow write/modify access to construction sites for active admins, and updates for assigned engineers
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (
        isActiveUser() && (
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && siteId in getUserData().assignedSites) ||
          (isSiteEngineer() && siteId in getSiteEngineerData().assignedSites)
        )
      );
    }

    match /reports/{updateId} {
      // Allow active users (admins or engineers) to read and write daily updates
      allow read, write: if isActiveUser();
    }

    match /dailyUpdates/{updateId} {
      // Allow active users (admins or engineers) to read and write daily updates
      allow read, write: if isActiveUser();
    }

    match /expenses/{expenseId} {
      // Allow active users to read and write general expenses
      allow read, write: if isActiveUser();
    }

    match /attendance/{attendanceId} {
      // Allow active users to read and write attendance
      allow read, write: if isActiveUser();
    }

    match /sitePhotos/{photoId} {
      // Allow active users to read and write site photos
      allow read, write: if isActiveUser();
    }

    match /siteAssignments/{assignmentId} {
      // Allow read access to active users (admins or engineers)
      allow read: if isActiveUser();
      
      // Allow write/modify access only to active admins
      allow write: if isAdmin();
    }

    match /materials/{materialId} {
      // Allow read access to admins, or active engineers if the site is in their assignedSites list
      allow read: if isAdmin() || (
        isActiveUser() && (
          resource == null || 
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && resource.data.siteId in getUserData().assignedSites) ||
          (isSiteEngineer() && resource.data.siteId in getSiteEngineerData().assignedSites)
        )
      );
      
      // Allow creation only by active engineers assigned to the site, saving under their own UID
      allow create: if isActiveUser() && 
                    (
                      ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (getUserData().role == 'site_engineer' || getUserData().role == 'engineer')) && request.resource.data.siteId in getUserData().assignedSites) ||
                      (isSiteEngineer() && request.resource.data.siteId in getSiteEngineerData().assignedSites)
                    ) &&
                    request.resource.data.engineerId == request.auth.uid;
      
      // Updates and deletes are restricted to admin
      allow update, delete: if isAdmin();
    }

    match /workers/{workerId} {
      allow read: if isAdmin() || (
        isActiveUser() && (
          resource == null || 
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && resource.data.siteId in getUserData().assignedSites) ||
          (isSiteEngineer() && resource.data.siteId in getSiteEngineerData().assignedSites)
        )
      );
      allow write: if isAdmin() || (
        isActiveUser() && 
        (
          ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (getUserData().role == 'site_engineer' || getUserData().role == 'engineer')) && request.resource.data.siteId in getUserData().assignedSites) ||
          (isSiteEngineer() && request.resource.data.siteId in getSiteEngineerData().assignedSites)
        ) &&
        request.resource.data.engineerId == request.auth.uid
      );
    }

    match /labourAttendance/{attendanceId} {
      allow read: if isAdmin() || (
        isActiveUser() && (
          resource == null || 
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && resource.data.siteId in getUserData().assignedSites) ||
          (isSiteEngineer() && resource.data.siteId in getSiteEngineerData().assignedSites)
        )
      );
      allow write: if isAdmin() || (
        isActiveUser() && 
        (
          ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (getUserData().role == 'site_engineer' || getUserData().role == 'engineer')) && request.resource.data.siteId in getUserData().assignedSites) ||
          (isSiteEngineer() && request.resource.data.siteId in getSiteEngineerData().assignedSites)
        ) &&
        request.resource.data.markedBy == request.auth.uid
      );
    }

    match /labourDailyCount/{countId} {
      allow read: if isAdmin() || (
        isActiveUser() && (
          resource == null || 
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && resource.data.siteId in getUserData().assignedSites) ||
          (isSiteEngineer() && resource.data.siteId in getSiteEngineerData().assignedSites)
        )
      );
      allow write: if isAdmin() || (
        isActiveUser() && 
        (
          ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (getUserData().role == 'site_engineer' || getUserData().role == 'engineer')) && request.resource.data.siteId in getUserData().assignedSites) ||
          (isSiteEngineer() && request.resource.data.siteId in getSiteEngineerData().assignedSites)
        ) &&
        request.resource.data.engineerId == request.auth.uid
      );
    }

    match /labourCategories/{categoryId} {
      allow read: if isActiveUser();
      allow write: if isAdmin();
    }

    match /siteLabourEntries/{entryId} {
      allow read: if isAdmin() || (
        isActiveUser() && (
          resource == null || 
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && resource.data.siteId in getUserData().assignedSites) ||
          (isSiteEngineer() && resource.data.siteId in getSiteEngineerData().assignedSites)
        )
      );
      allow write: if isAdmin() || (
        isActiveUser() && 
        (
          ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (getUserData().role == 'site_engineer' || getUserData().role == 'engineer')) && request.resource.data.siteId in getUserData().assignedSites) ||
          (isSiteEngineer() && request.resource.data.siteId in getSiteEngineerData().assignedSites)
        ) &&
        request.resource.data.engineerId == request.auth.uid
      );
    }


    match /leaves/{leaveId} {
      allow read, write: if isActiveUser();
    }

    match /engineerLocations/{locationId} {
      allow read: if isActiveUser();
      allow write: if isActiveUser() && request.resource.data.engineerId == request.auth.uid;
    }

    match /documents/{docId} {
      allow read, write: if isActiveUser();
    }

    match /activityLogs/{logId} {
      allow read, write: if isActiveUser();
    }

    match /activities/{activityId} {
      allow read, write: if isActiveUser();
    }

    match /notifications/{notificationId} {
      allow read, write: if isActiveUser();
    }

    match /approvals/{approvalId} {
      allow read, write: if isActiveUser();
    }
    
  }
}
